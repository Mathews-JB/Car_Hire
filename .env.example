# Database Configuration
DB_HOST=localhost
DB_NAME=car_higher
DB_USER=root
DB_PASS=

# Lenco Payment Gateway
LENCO_IS_LIVE=false

# Lenco Sandbox Keys
LENCO_SANDBOX_PUBLIC_KEY=your_sandbox_public_key
LENCO_SANDBOX_SECRET_KEY=your_sandbox_secret_key

# Lenco Production Keys
LENCO_LIVE_PUBLIC_KEY=your_production_public_key
LENCO_LIVE_SECRET_KEY=your_production_secret_key

# SMTP Configuration
SMTP_HOST=ssl://smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SUPPORT_EMAIL=your_email@gmail.com

# WhatsApp Business API (Twilio)
# Get credentials at: https://www.twilio.com/console
# Enable WhatsApp Sandbox: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_SIMULATE=true
TWILIO_SMS_FROM=
SMS_SIMULATE=true

# OCR Document Verification
# Option 1: Google Cloud Vision API (recommended for production)
# Enable at: https://console.cloud.google.com/apis/library/vision.googleapis.com
GOOGLE_VISION_API_KEY=your_google_vision_api_key

# Option 2: Local Tesseract OCR (free, works offline)
# Windows: https://github.com/UB-Mannheim/tesseract/wiki
# Linux: sudo apt install tesseract-ocr
TESSERACT_PATH=tesseract
